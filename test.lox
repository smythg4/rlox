var name = "world";

{
  var greeting = "Hello, " + name + "!";
  print greeting;
}

var x = 10;
var y = 3;

if (x > y) {
  print x - y;
} else {
  print y - x;
}

// and: both must be true
if (x > 0 and y > 0) {
  print "both positive";
}

// and: short-circuits on false left
if (x < 0 and y > 0) {
  print "unreachable";
} else {
  print "x is not positive";
}

// or: short-circuits on true left
if (x > 0 or y > 100) {
  print "x is positive";
}

// or: falls through to right when left is false
if (x < 0 or y > 0) {
  print "y is positive";
}

// while loop
var i = 0;
while (i < 5) {
  i = i + 1;
  print i;
}

// for loop with and condition, nested in while
var w = 0;
while (w < 6) {
  for (var f = 10; f < 14 and w < 3; f = f + 1) {
    print f;
  }
  w = w + 1;
  print w;
}
