// --- test gc ---
  fun make_garbage() {
    fun inner() { return 1; }
  }
  make_garbage();
  make_garbage();
  make_garbage();

// --- closures: basic capture ---
fun make_adder(x) {
  fun add(y) {
    return x + y;
  }
  return add;
}

var add5 = make_adder(5);
print add5(3);
print add5(10);

// --- closures: mutation over multiple calls ---
fun make_counter(start) {
  var count = start;
  fun increment() {
    count = count + 1;
    return count;
  }
  return increment;
}

var counter = make_counter(0);
print counter();
print counter();
print counter();

// --- closures: upvalue closed over after block scope exits ---
fun make_adder2(x) {
  {
    var offset = 100;
    fun add(y) {
      return x + y + offset;
    }
    return add;
  }
}

var add5_offset = make_adder2(5);
print add5_offset(3);
