// --- closures that become unreachable ---
fun make_garbage() {
  fun inner() { return 1; }
}
var g = 0;
while (g < 10) {
  make_garbage();
  g = g + 1;
}

// --- concatenated strings that become unreachable ---
var i = 0;
while (i < 20) {
  var s = "hel" + "lo";
  var t = "foo" + "bar";
  var u = "baz" + "qux";
  i = i + 1;
}

// --- upvalues that become unreachable ---
{
  fun make_counter() {
    var n = 0;
    fun increment() {
      n = n + 1;
      return n;
    }
    return increment;
  }
  var c1 = make_counter();
  var c2 = make_counter();
  var c3 = make_counter();
  c1(); c1(); c1();
  c2(); c2();
  c3();
}

// --- instances that become unreachable ---
class Crumb {}
var j = 0;
while (j < 10) {
  var c = Crumb();
  c.x = j;
  c.y = j + 1;
  c.label = "crumb" + "s";
  j = j + 1;
  c.name = "blargh";
}

// --- instances with closure fields ---
class Box {}
{
  fun make_adder(x) {
    fun add(y) { return x + y; }
    return add;
  }
  var b = Box();
  b.add5 = make_adder(5);
  b.add10 = make_adder(10);
}

print "done";
